// `else if` chain classifying a score into a grade.
// main returns grade(85) = 66 ('B' in ASCII).

fn grade(x: i64) -> i64 {
  if x >= 90 { 65 }      // 'A'
  else if x >= 80 { 66 } // 'B'
  else if x >= 70 { 67 } // 'C'
  else if x >= 60 { 68 } // 'D'
  else { 70 }            // 'F'
}

fn main() -> i32 {
  grade(85)
}
