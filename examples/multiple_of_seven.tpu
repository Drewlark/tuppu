// Find the first multiple of seven in [1, n) using `yield` for early return.
// main returns 7, the first multiple of seven.

fn first_multiple_of_seven(n: i64) -> i64 {
  mut i = 1
  while i < n {
    if i % 7 == 0 {
      yield i
    }
    i = i + 1
  }
  0
}

fn main() -> i32 {
  first_multiple_of_seven(100)
}
